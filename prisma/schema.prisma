generator client {
  provider   = "prisma-client-js"
  output     = "../src/db/generated/prisma"
  engineType = "client"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  USER
}

model User {
  id       Int    @id @default(autoincrement())
  email    String @unique
  password String
  role     Role   @default(USER)

  @@map("users")
}
